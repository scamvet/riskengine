# abuse.ch / URLhaus - required since 2025-06-30. Get one free at https://auth.abuse.ch/
# Link at least two auth providers on that account.
ABUSECH_AUTH_KEY=

# PhishTank application key - optional, raises rate limits
PHISHTANK_APP_KEY=

# Tranco - only needed for custom list generation (see LEGAL.md, Cloudflare Radar note)
TRANCO_ACCOUNT_EMAIL=
TRANCO_API_KEY=
